<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:aapt="http://schemas.android.com/aapt"
        android:width="108dp"
        android:height="108dp"
        android:viewportWidth="108"
        android:viewportHeight="108">

    <!-- Green aura -->
    <path android:pathData="M54,14 A40,40 0 0,1 54,94 A40,40 0 0,1 54,14Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="40">
                <item android:offset="0" android:color="#5957E08A"/>
                <item android:offset="1" android:color="#0057E08A"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Full orbit ring (dark stroke) -->
    <path
        android:pathData="M54,25 A29,29 0 0,1 54,83 A29,29 0 0,1 54,25"
        android:strokeColor="#33433C"
        android:strokeWidth="5"
        android:fillColor="#00000000"/>

    <!-- Green arc (~94.5° from top, clockwise) -->
    <path
        android:pathData="M54,25 A29,29 0 0,1 82.91,56.27"
        android:strokeColor="#57E08A"
        android:strokeWidth="5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"/>

    <!-- Center dot glow -->
    <path android:pathData="M54,40 A14,14 0 0,1 54,68 A14,14 0 0,1 54,40Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="14">
                <item android:offset="0" android:color="#8057E08A"/>
                <item android:offset="1" android:color="#0057E08A"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Center dot -->
    <path
        android:pathData="M54,46 A8,8 0 0,1 54,62 A8,8 0 0,1 54,46Z"
        android:fillColor="#57E08A"/>

</vector>
